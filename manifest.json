{
    "manifest_version": 3,
    "name": "flow-Assistant",
    "version": "1.0",
    "description": "A Chrome Extension side panel bot for automating interactions on labs.google/fx/tools/flow",
    "permissions": [
        "sidePanel",
        "activeTab",
        "scripting",
        "storage",
        "unlimitedStorage"
    ],
    "host_permissions": [
        "https://labs.google/*"
    ],
    "content_scripts": [
        {
            "matches": ["https://labs.google/*", "https://*.google.com/*"],
            "js": ["content.js"]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Open flow-Assistant",
        "default_icon": "icons/icon48.png"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    }
}